{
  "title": "Mono",
  "children": [
    {
      "title": "Overview",
      "lines": [
        "Six-track digital",
        "machine synth with",
        "a 64-step lock",
        "sequencer.",
        "",
        "Open from Schwung's",
        "overtake menu."
      ]
    },
    {
      "title": "Tracks",
      "lines": [
        "Top-row pads 1-6",
        "select tracks.",
        "Pad 7 changes the",
        "track machine.",
        "Pad 8 starts or",
        "stops sequencing.",
        "",
        "Lower 3 pad rows",
        "play notes."
      ]
    },
    {
      "title": "Steps",
      "lines": [
        "Step buttons edit",
        "the current page",
        "of 16 steps.",
        "Red = trig.",
        "Purple = locked.",
        "White = playing.",
        "",
        "Arrows change the",
        "16-step page."
      ]
    },
    {
      "title": "Play Window",
      "lines": [
        "Shift + top pad 8",
        "opens Seq Setup.",
        "",
        "Knob 1: start.",
        "Knob 2: length.",
        "Knob 3: order.",
        "Knob 4: step page.",
        "",
        "Orders are Forward,",
        "Reverse, Pendulum",
        "and Random."
      ]
    },
    {
      "title": "Locks",
      "lines": [
        "Hold a step and",
        "turn a knob to",
        "lock that value",
        "on the step.",
        "",
        "Hold Shift too",
        "and turn the knob",
        "to remove its lock.",
        "",
        "Press Record while",
        "playing, then turn",
        "knobs to live-lock",
        "the current step.",
        "Continuous locks",
        "glide; choices step."
      ]
    },
    {
      "title": "Pages",
      "lines": [
        "Turn the jog for",
        "SYNTH, AMP, FILTER,",
        "EFFECT and LFO",
        "pages. Each page",
        "maps to knobs 1-8.",
        "",
        "On any page, hold",
        "Shift and turn a",
        "knob for its second",
        "eight controls.",
        "",
        "LFO DEST names all",
        "112 sound params plus",
        "Pitch. LFOs can",
        "modulate each other.",
        "TRIG and WAVE use",
        "five named choices."
      ]
    },
    {
      "title": "Presets",
      "lines": [
        "Hold Shift and",
        "click the jog to",
        "open presets.",
        "",
        "Save current keeps",
        "all 6 sounds, 64",
        "steps, play window,",
        "order and locks."
      ]
    }
  ]
}
