{
  "title": "Mono Voice",
  "children": [
    {
      "title": "Overview",
      "lines": [
        "Digital machine",
        "synth for a normal",
        "Move track.",
        "",
        "Choose SuperWave,",
        "SID, DigiPRO or",
        "FM+ Static, then",
        "play from Move's",
        "pads or sequencer."
      ]
    },
    {
      "title": "Editing",
      "lines": [
        "Jog or arrows:",
        "change data page.",
        "",
        "Knobs 1-8 edit",
        "that page.",
        "",
        "Hold Shift and",
        "turn the jog to",
        "change machine.",
        "",
        "On SYNTH, hold",
        "Shift and turn",
        "knobs for eight",
        "more controls."
      ]
    },
    {
      "title": "Pages",
      "lines": [
        "SYNTH is unique",
        "to each machine.",
        "AMP, FILTER and",
        "EFFECT shape the",
        "track. LFO 1-3",
        "can target Pitch or",
        "all 64 sound params,",
        "including each",
        "other's settings.",
        "DEST shows the name."
      ]
    },
    {
      "title": "Saving",
      "lines": [
        "Use Schwung User",
        "Presets for sound.",
        "",
        "Move sequences live",
        "in the Move Set.",
        "Shift + Step 1",
        "opens Set Overview."
      ]
    }
  ]
}
